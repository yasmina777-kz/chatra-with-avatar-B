# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (production):
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/chatra

# SQLite (local development):
# DATABASE_URL=sqlite:///./chatra.db

# ── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random secret in production!
SECRET_KEY=change-me-to-a-very-long-random-secret-string

# ── OpenAI API ────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Paste it here WITHOUT quotes:
OPENAI_API_KEY=sk-...your-key-here...

# ── Upload settings ───────────────────────────────────────────────────────────
# Base URL used to build file download links returned by /upload/
# In production set to your domain, e.g.: https://api.yourdomain.com
APP_BASE_URL=http://localhost:8000

# ── RAG (Retrieval-Augmented Generation) ─────────────────────────────────────
# Embedding model (text-embedding-3-small is cheapest, 1536-dim)
EMBED_MODEL=text-embedding-3-small
# LLM for answering queries
CHAT_MODEL=gpt-4o-mini
# Tokens per chunk (300–800 recommended)
CHUNK_SIZE=512
# Overlap between consecutive chunks
CHUNK_OVERLAP=64
# How many chunks to retrieve per query
TOP_K=5
# Hard token cap sent to LLM (never exceeded)
MAX_CONTEXT_TOKENS=3000

# ── Yandex Object Storage ────────────────────────────────────────────────────
# Create a service account key in Yandex Cloud Console → Object Storage
# Leave blank to fall back to local disk storage
YC_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
YC_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
YC_BUCKET_NAME=your-bucket-name
